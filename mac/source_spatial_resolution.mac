##########################################################
# Point Sources for Spatial Resolution — PGLS
# NEMA NU 2-2018: 6 positions
# Axial positions from Zhang et al. 2024, Table 2:
#   z = 18.5 cm  (1/8 AFOV = 148.2/8)
#   z = 74.0 cm  (1/2 AFOV = 148.2/2)
# Radial offsets: 1, 10, 20 cm
##########################################################

# ── Position group 1: z = 18.5 cm (1/8 AFOV) ──

# Source 1: z=18.5cm, r=1cm
/gate/source/addSource point_source_1
/gate/source/point_source_1/setActivity 300 kBq
/gate/source/point_source_1/gps/particle e+
/gate/source/point_source_1/setForcedUnstableFlag true
/gate/source/point_source_1/setForcedHalfLife 6586.2 s
/gate/source/point_source_1/gps/energytype Fluor18
/gate/source/point_source_1/gps/type Volume
/gate/source/point_source_1/gps/shape Sphere
/gate/source/point_source_1/gps/radius 0.025 cm
/gate/source/point_source_1/gps/angtype iso
/gate/source/point_source_1/gps/centre 1.0 0. 18.5 cm

# Source 2: z=18.5cm, r=10cm
/gate/source/addSource point_source_2
/gate/source/point_source_2/setActivity 300 kBq
